{
  "schema_version": "1.0.0",
  "run_id_prefix": "run",
  "app": {
    "start_command": [
      "{python}",
      "-m",
      "uvicorn",
      "app.main:app",
      "--host",
      "127.0.0.1",
      "--port",
      "8765"
    ],
    "base_url": "http://127.0.0.1:8765",
    "health_url": "http://127.0.0.1:8765/api/products",
    "cwd": "."
  },
  "stage0": {
    "restore_files": [
      {
        "source": "app/buggy_main_seed.py",
        "target": "app/main.py"
      }
    ],
    "bug_seed": "default_buggy_shop_seed"
  },
  "personas": [
    {
      "persona_id": "persona_gb_flow",
      "goal": "Walk the group-buy lifecycle in order: click the Group Buy button, reach the Checkout page, Place Order, reach the Order Confirmation page, then open the Group Buy page. Flag anything that interrupts or misrepresents this journey, especially broken transitions between steps. Group buy may be a placeholder; report only observed inconsistencies and never assume planted bugs.",
      "traits": {
        "patience": "medium",
        "attention_to_detail": "high",
        "shopping_style": "goal_directed"
      },
      "constraints": {
        "max_duration_ms": 120000,
        "max_actions": 30,
        "viewport": {
          "width": 1440,
          "height": 900
        },
        "headless": false,
        "slow_mo_ms": 250
      },
      "model": {
        "provider": "openai",
        "model_name": "gpt-4o-mini",
        "mode": "live",
        "reasoning_effort": null
      }
    },
    {
      "persona_id": "persona_gb_price",
      "goal": "Move through the group-buy checkout (Group Buy -> Checkout -> Place Order -> Confirmation) auditing pricing math: unit prices, discounts, quantities, payable totals, and the confirmation screen. Flag any internal inconsistency between displayed numbers. Report only observed evidence.",
      "traits": {
        "patience": "high",
        "attention_to_detail": "very_high",
        "shopping_style": "comparison_shopper"
      },
      "constraints": {
        "max_duration_ms": 120000,
        "max_actions": 35,
        "viewport": {
          "width": 1440,
          "height": 900
        },
        "headless": false,
        "slow_mo_ms": 250
      },
      "model": {
        "provider": "openai",
        "model_name": "gpt-4o-mini",
        "mode": "live",
        "reasoning_effort": null
      }
    },
    {
      "persona_id": "persona_gb_contract",
      "goal": "Walk the group-buy flow probing UI-observable source-of-truth mismatches: identifiers shown vs used, boundary quantities, and invalid inputs the forms accept. Stay within what the browser UI exposes; do not claim API-level findings you cannot observe. Report only observed evidence.",
      "traits": {
        "patience": "high",
        "attention_to_detail": "high",
        "shopping_style": "exploratory"
      },
      "constraints": {
        "max_duration_ms": 120000,
        "max_actions": 30,
        "viewport": {
          "width": 1280,
          "height": 800
        },
        "headless": false,
        "slow_mo_ms": 250
      },
      "model": {
        "provider": "openai",
        "model_name": "gpt-4o-mini",
        "mode": "live",
        "reasoning_effort": null
      }
    },
    {
      "persona_id": "persona_gb_security",
      "goal": "Walk the group-buy flow flagging any visible permission, ownership, or finalization issue from a single session, such as controls that let a non-owner finalize or place an order before the group is complete. Treat cross-session isolation as a limitation, not an invented bug. Report only observed evidence.",
      "traits": {
        "patience": "medium",
        "attention_to_detail": "high",
        "shopping_style": "goal_directed"
      },
      "constraints": {
        "max_duration_ms": 120000,
        "max_actions": 30,
        "viewport": {
          "width": 1440,
          "height": 900
        },
        "headless": false,
        "slow_mo_ms": 250
      },
      "model": {
        "provider": "openai",
        "model_name": "gpt-4o-mini",
        "mode": "live",
        "reasoning_effort": null
      }
    },
    {
      "persona_id": "persona_gb_data_integrity",
      "goal": "Walk the group-buy flow and check invariant drift: participant counts, order/group status, status regressions across the lifecycle, and stale state after returning to the Group Buy page. Flag inconsistencies between what an action did and what later screens show. Report only observed evidence.",
      "traits": {
        "patience": "high",
        "attention_to_detail": "very_high",
        "shopping_style": "exploratory"
      },
      "constraints": {
        "max_duration_ms": 150000,
        "max_actions": 40,
        "viewport": {
          "width": 390,
          "height": 844
        },
        "headless": false,
        "slow_mo_ms": 250
      },
      "model": {
        "provider": "openai",
        "model_name": "gpt-4o-mini",
        "mode": "live",
        "reasoning_effort": null
      }
    }
  ],
  "verifier": {
    "expected_behavior_sources": [
      "specs/app_expected_behavior.md"
    ],
    "model": {
      "provider": "openai",
      "model_name": "gpt-5",
      "mode": "live",
      "reasoning_effort": "medium"
    }
  },
  "fixing": {
    "model": {
      "provider": "openai",
      "model_name": "gpt-5.3-codex",
      "mode": "live",
      "reasoning_effort": "high"
    }
  },
  "repo": {
    "path": ".",
    "entrypoint": "app/main.py",
    "test_command": "pytest"
  },
  "sandbox_root": ".sandbox",
  "promotion_policy": {
    "target_file": "app/main.py",
    "requires_tests_green": true,
    "requires_contract_validation": true
  }
}
