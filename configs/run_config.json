{
  "schema_version": "1.0.0",
  "run_id_prefix": "run",
  "app": {
    "start_command": [
      "{python}",
      "-m",
      "uvicorn",
      "app.main:app",
      "--host",
      "127.0.0.1",
      "--port",
      "8765"
    ],
    "base_url": "http://127.0.0.1:8765",
    "health_url": "http://127.0.0.1:8765/api/products",
    "cwd": "."
  },
  "stage0": {
    "restore_files": [
      {
        "source": "app/buggy_main_seed.py",
        "target": "app/main.py"
      }
    ],
    "bug_seed": "default_buggy_shop_seed"
  },
  "personas": [
    {
      "persona_id": "persona_general_shopper",
      "goal": "Explore the shopping site as a real customer and flag any inconsistencies between actions, displayed state, prices, totals, messages, or checkout outcomes.",
      "traits": {
        "patience": "medium",
        "attention_to_detail": "high",
        "shopping_style": "goal_directed"
      },
      "constraints": {
        "max_duration_ms": 120000,
        "max_actions": 30,
        "viewport": {
          "width": 1440,
          "height": 900
        },
        "headless": false,
        "slow_mo_ms": 250
      },
      "model": {
        "provider": "openai",
        "model_name": "gpt-4o-mini",
        "mode": "live",
        "reasoning_effort": null
      }
    },
    {
      "persona_id": "persona_price_auditor",
      "goal": "Shop carefully while checking whether product prices, quantities, subtotals, discounts, cart totals, and checkout totals stay internally consistent.",
      "traits": {
        "patience": "high",
        "attention_to_detail": "very_high",
        "shopping_style": "comparison_shopper"
      },
      "constraints": {
        "max_duration_ms": 120000,
        "max_actions": 35,
        "viewport": {
          "width": 1440,
          "height": 900
        },
        "headless": false,
        "slow_mo_ms": 250
      },
      "model": {
        "provider": "openai",
        "model_name": "gpt-4o-mini",
        "mode": "live",
        "reasoning_effort": null
      }
    },
    {
      "persona_id": "persona_impatient_buyer",
      "goal": "Move quickly through browsing, cart changes, and checkout while flagging confusing feedback, stale state, or results that do not match recent actions.",
      "traits": {
        "patience": "low",
        "attention_to_detail": "medium",
        "shopping_style": "fast_checkout"
      },
      "constraints": {
        "max_duration_ms": 90000,
        "max_actions": 24,
        "viewport": {
          "width": 1280,
          "height": 800
        },
        "headless": false,
        "slow_mo_ms": 250
      },
      "model": {
        "provider": "openai",
        "model_name": "gpt-4o-mini",
        "mode": "live",
        "reasoning_effort": null
      }
    },
    {
      "persona_id": "persona_edge_case_explorer",
      "goal": "Try realistic edge-case shopping behavior such as changing quantities, removing items, revisiting pages, and checking whether the site remains consistent.",
      "traits": {
        "patience": "high",
        "attention_to_detail": "high",
        "shopping_style": "exploratory"
      },
      "constraints": {
        "max_duration_ms": 150000,
        "max_actions": 40,
        "viewport": {
          "width": 390,
          "height": 844
        },
        "headless": false,
        "slow_mo_ms": 250
      },
      "model": {
        "provider": "openai",
        "model_name": "gpt-4o-mini",
        "mode": "live",
        "reasoning_effort": null
      }
    }
  ],
  "verifier": {
    "expected_behavior_sources": [
      "specs/app_expected_behavior.md"
    ],
    "model": {
      "provider": "openai",
      "model_name": "gpt-5",
      "mode": "live",
      "reasoning_effort": "medium"
    }
  },
  "fixing": {
    "model": {
      "provider": "openai",
      "model_name": "gpt-5.3-codex",
      "mode": "live",
      "reasoning_effort": "high"
    }
  },
  "repo": {
    "path": ".",
    "entrypoint": "app/main.py",
    "test_command": "pytest"
  },
  "sandbox_root": ".sandbox",
  "promotion_policy": {
    "target_file": "app/main.py",
    "requires_tests_green": true,
    "requires_contract_validation": true
  }
}
